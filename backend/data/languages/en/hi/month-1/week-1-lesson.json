      "title": "Hindi Sentence Structure (SOV)",
      "pattern": "Subject + Object + Verb",
      "examples": [
        { "native": "I learn Hindi.", "target": "मैं हिंदी सीखता हूँ।", "translation": "Main (I) hindi (Hindi) seekhta hoon (learn)." },

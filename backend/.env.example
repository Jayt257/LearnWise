# backend/.env.example
# Template for required environment variables.
# Copy this to .env and fill in real values for local development.
# For production (Render), add these as Environment Variables in the dashboard.
# NEVER commit a .env file with real secrets.

# ── Database ──────────────────────────────────────────────────
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
# On Render: copy the "Internal Database URL" from your PostgreSQL addon
DATABASE_URL=postgresql://postgres:yourpassword@localhost:5432/learnwise

# ── JWT ───────────────────────────────────────────────────────
# Generate a strong key: openssl rand -hex 32
SECRET_KEY=replace-with-a-64-character-random-string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# ── Groq AI ───────────────────────────────────────────────────
# Get from: https://console.groq.com
GROQ_API_KEY=gsk_your_groq_api_key_here
GROQ_MODEL=llama-3.1-8b-instant

# ── Whisper STT ───────────────────────────────────────────────
# Options: tiny, small, medium, turbo
# Free tier (512MB): tiny only
# Standard tier (2GB): small (recommended)
# Pro tier (4GB): medium or turbo
WHISPER_MODEL=small

# ── App ───────────────────────────────────────────────────────
APP_NAME=LearnWise
DEBUG=false

# ── CORS ──────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
# On Render: set to your frontend service URL
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ── Admin Seed Account ────────────────────────────────────────
ADMIN_EMAIL=admin@learnwise.app
ADMIN_PASSWORD=ChangeThisInProduction!
ADMIN_USERNAME=admin

# ── Scoring ───────────────────────────────────────────────────
# -1 = disabled (use real 50% threshold) — keep this in production
SCORE_THRESHOLD_OVERRIDE=-1

# ── Data directory ────────────────────────────────────────────
# Relative to backend/ — where curriculum JSON files live
DATA_DIR=data

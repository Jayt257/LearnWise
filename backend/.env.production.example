# backend/.env.production.example
# Template for PRODUCTION environment variables on your VPS.
# On your VPS: copy this to /home/learnwise/app/backend/.env
# and fill in ALL real values before starting the server.
# NEVER commit this file to Git.

# ── PostgreSQL ─────────────────────────────────────────────────
POSTGRES_DB=learnwise
POSTGRES_USER=learnwise_user
# Use: openssl rand -hex 24  to generate this
POSTGRES_PASSWORD=GENERATE_A_STRONG_PASSWORD_HERE

# ── FastAPI Backend ────────────────────────────────────────────
# Use: openssl rand -hex 32  to generate this
SECRET_KEY=GENERATE_A_64_CHAR_RANDOM_HEX_STRING_HERE
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# ── Groq AI ────────────────────────────────────────────────────
# Get from: https://console.groq.com
GROQ_API_KEY=gsk_your_real_groq_key_here
GROQ_MODEL=llama-3.1-8b-instant

# ── Whisper STT ───────────────────────────────────────────────
WHISPER_MODEL=small

# ── CORS - YOUR DOMAIN ────────────────────────────────────────
# Replace with your actual domain name
ALLOWED_ORIGINS=https://YOUR_DOMAIN.com,https://www.YOUR_DOMAIN.com
VITE_API_BASE_URL=https://YOUR_DOMAIN.com

# ── Admin Seed Account ────────────────────────────────────────
ADMIN_EMAIL=admin@YOUR_DOMAIN.com
ADMIN_PASSWORD=CreateAStrongPasswordHere!
ADMIN_USERNAME=admin

# ── App ───────────────────────────────────────────────────────
APP_NAME=LearnWise
DEBUG=false
DATA_DIR=data
SCORE_THRESHOLD_OVERRIDE=-1
